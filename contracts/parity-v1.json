          "id": "versionless-merge-preserves-unknown",
          "initial": {
            "mode": "json",
            "document": {
              "confirmBeforeDelete": true,
              "keyBindings": {
                "nextImage": "ArrowRight",
                "futureChord": { "mode": "keep" }
              },
              "futureRoot": { "owner": "browser" },
              "thumbnailStatusBorders": {
                "futureStatus": "keep",
                "favorite": {
                  "enabled": false,
                  "color": "#112233",
                  "futureFavorite": 17
                },
                "enhanced": {
                  "enabled": true,
                  "color": "#445566",
                  "futureEnhanced": { "mode": "keep" }
                }
              }
            }
          },
          "localConfirmBeforeDelete": false,
          "operations": [
            { "action": "confirm", "value": false },
