    {
      "id": "PV-REC-001",
      "kind": "recent-folder-authority",
      "cases": [
        {
          "id": "supported-shared-wins",
          "initial": {
            "mode": "json",
            "document": {
              "version": 1,
              "lastFolderSet": ["${ROOT}/shared"],
              "recentFolderSets": [["${ROOT}/shared"]],
              "futureRoot": { "keep": true }
            }
          },
          "localFolderSet": ["${ROOT}/local"],
          "expected": {
            "readOk": true,
            "exists": true,
            "selectedFolderSet": ["${ROOT}/shared"],
            "fileExists": true,
            "bytesUnchanged": true
          }
        },
        {
          "id": "supported-explicit-empty-wins",
          "initial": {
            "mode": "json",
            "document": {
              "version": 1,
              "lastFolderSet": [],
              "recentFolderSets": []
            }
          },
          "localFolderSet": ["${ROOT}/local"],
          "expected": {
            "readOk": true,
            "exists": true,
            "selectedFolderSet": [],
            "fileExists": true,
            "bytesUnchanged": true
          }
        },
        {
          "id": "utf8-bom-supported",
          "initial": {
            "mode": "bytes-base64",
            "base64": "77u/eyJ2ZXJzaW9uIjoxLCJsYXN0Rm9sZGVyU2V0IjpbXSwicmVjZW50Rm9sZGVyU2V0cyI6W10sImZ1dHVyZVJvb3QiOnsia2VlcCI6dHJ1ZX19"
          },
          "localFolderSet": ["${ROOT}/local"],
          "operations": [
            { "action": "merge", "folder": "${ROOT}/bom-write" }
          ],
          "expected": {
            "readOk": true,
            "exists": true,
            "selectedFolderSet": [],
            "statuses": ["Succeeded"],
            "canonicalUtf8WithoutBom": true,
            "unknownRoot": {
              "futureRoot": { "keep": true }
            },
            "fileExists": true,
            "bytesUnchanged": false
          }
        },
        {
          "id": "invalid-utf8-uses-local-fallback",
          "initial": {
            "mode": "bytes-base64",
            "base64": "eyJ2ZXJzaW9uIjoxLCJsYXN0Rm9sZGVyU2V0IjpbXSwicmVjZW50Rm9sZGVyU2V0cyI6W10sImZ1dHVyZVJvb3QiOiLDKCJ9"
          },
          "localFolderSet": ["${ROOT}/local"],
          "operations": [
