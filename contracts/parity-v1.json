        },
        {
          "id": "nfkc-dotted-i-equivalence",
          "samples": [
            {
              "input": "\uff23\uff21\uff34, \u0130",
              "normalized": "\uff23\uff21\uff34, \u0130",
              "comparisonKey": "cat, i\u0307"
            },
            {
              "input": "cat, i\u0307",
              "normalized": "cat, i\u0307",
              "comparisonKey": "cat, i\u0307"
            }
          ]
        },
        {
          "id": "greek-cyrillic-equivalence",
          "samples": [
            {
              "input": "\u041c\u041e\u0421\u041a\u0412\u0410, \u039f\u03a3",
