              "comparisonKey": "\u043c\u043e\u0441\u043a\u0432\u0430, \u03bf\u03c3"
            },
            {
              "input": "\u043c\u043e\u0441\u043a\u0432\u0430, \u03bf\u03c3",
              "normalized": "\u043c\u043e\u0441\u043a\u0432\u0430, \u03bf\u03c3",
              "comparisonKey": "\u043c\u043e\u0441\u043a\u0432\u0430, \u03bf\u03c3"
