{
  "name": "h000025-photoviewer",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first PhotoViewer focused on extreme runtime lightness without removing existing user-facing functions",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "playwright": "playwright",
    "comfy:smoke": "node scripts/comfy_upscale_smoke.js",
    "ncnn:smoke": "node scripts/ncnn_upscale_smoke.js",
    "perf:record": "node scripts/perf/record.mjs",
    "perf:compare": "node scripts/perf/compare.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "koffi": "3.1.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-testing-library": "^7.16.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "turbo": "2.10.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
