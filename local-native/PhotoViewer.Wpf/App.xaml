<Application x:Class="PhotoViewer.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PhotoViewer.Wpf">
  <Application.Resources>

    <!-- ═══════════ Design tokens (source of truth: browser globals.css) ═══════════ -->
    <Color x:Key="BgPrimaryColor">#08080C</Color>
    <Color x:Key="BgSecondaryColor">#101018</Color>
    <Color x:Key="BgTertiaryColor">#181824</Color>
    <Color x:Key="BgElevatedColor">#1C1C2E</Color>
    <Color x:Key="AccentColor">#6366F1</Color>
    <Color x:Key="AccentLightColor">#818CF8</Color>
    <Color x:Key="FavoriteColor">#F43F5E</Color>

    <SolidColorBrush x:Key="BgPrimary" Color="#08080C"/>
    <SolidColorBrush x:Key="BgSecondary" Color="#101018"/>
    <SolidColorBrush x:Key="BgTertiary" Color="#181824"/>
    <SolidColorBrush x:Key="BgElevated" Color="#1C1C2E"/>
    <SolidColorBrush x:Key="HeaderBg" Color="#0B0B12"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#EEF0F6"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#7A7F9A"/>
    <SolidColorBrush x:Key="TextTertiary" Color="#50546E"/>
    <SolidColorBrush x:Key="Accent" Color="#6366F1"/>
    <SolidColorBrush x:Key="AccentLight" Color="#818CF8"/>
    <SolidColorBrush x:Key="Favorite" Color="#F43F5E"/>
    <SolidColorBrush x:Key="FavoriteText" Color="#FECDD3"/>
    <SolidColorBrush x:Key="FavoriteThumbnailStatusBorderBrush" Color="#FACC15"/>
    <LinearGradientBrush x:Key="EnhancedThumbnailStatusBorderBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#FF1744" Offset="0"/>
      <GradientStop Color="#FF9100" Offset="0.142857"/>
      <GradientStop Color="#FFEA00" Offset="0.285714"/>
      <GradientStop Color="#00E676" Offset="0.428571"/>
      <GradientStop Color="#00B8D4" Offset="0.571429"/>
      <GradientStop Color="#2979FF" Offset="0.714286"/>
      <GradientStop Color="#AA00FF" Offset="0.857143"/>
      <GradientStop Color="#FF1744" Offset="1"/>
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Success" Color="#10B981"/>
    <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerText" Color="#FECACA"/>
    <SolidColorBrush x:Key="GlassBorder" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="GlassBorderHover" Color="#26FFFFFF"/>
    <SolidColorBrush x:Key="HoverFill" Color="#14FFFFFF"/>
    <SolidColorBrush x:Key="SoftFill" Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="AccentSoft" Color="#1A6366F1"/>
    <SolidColorBrush x:Key="AccentGlass" Color="#296366F1"/>
    <SolidColorBrush x:Key="FavoriteSoft" Color="#1FF43F5E"/>
    <SolidColorBrush x:Key="SuccessSoft" Color="#1410B981"/>
    <SolidColorBrush x:Key="SuccessBorder" Color="#5710B981"/>

    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, monospace</FontFamily>

    <LinearGradientBrush x:Key="LogoBrush" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#818CF8" Offset="0"/>
      <GradientStop Color="#C084FC" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="FavStepGradient" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="#818CF8" Offset="0"/>
      <GradientStop Color="#6366F1" Offset="1"/>
    </LinearGradientBrush>

    <!-- ═══════════ Converters ═══════════ -->
    <local:MultiplyConverter x:Key="Multiply"/>
    <local:CountToVisibilityConverter x:Key="CountToVis"/>
    <local:BoolToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ═══════════ Base text ═══════════ -->
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
      <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <Style x:Key="SectionHeader" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
      <Setter Property="FontSize" Value="10.5"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <!-- ═══════════ Icon button (36x36) ═══════════ -->
    <Style x:Key="IconButton" TargetType="Button">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="36"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="8" Background="Transparent">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverFill}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="IconButtonActive" TargetType="Button" BasedOn="{StaticResource IconButton}">
      <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="8" Background="{StaticResource AccentGlass}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#356366F1"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Window caption buttons ═══════════ -->
    <Style x:Key="CaptionButton" TargetType="Button">
      <Setter Property="Width" Value="44"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="7" Background="Transparent">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverFill}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource CaptionButton}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="7" Background="Transparent">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#E5EF4444"/>
                <Setter Property="Foreground" Value="White"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Pill button ═══════════ -->
    <Style x:Key="Pill" TargetType="ToggleButton">
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Border x:Name="bd" CornerRadius="999" Padding="11,5"
                    Background="{StaticResource BgTertiary}"
                    BorderBrush="{StaticResource GlassBorder}" BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource GlassBorderHover}"/>
                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgElevated}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                <Setter TargetName="bd" Property="BorderBrush" Value="#806366F1"/>
                <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Sidebar link ═══════════ -->
    <Style x:Key="SidebarLink" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource AccentLight}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12.5"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter/>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Segmented control (RadioButton) ═══════════ -->
    <Style x:Key="Seg" TargetType="RadioButton">
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="bd" CornerRadius="6" Padding="10,5" Background="Transparent">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource Accent}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Ghost / danger action buttons ═══════════ -->
    <Style x:Key="GhostButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="8" Padding="10,0"
                    Background="{StaticResource SoftFill}"
                    BorderBrush="{StaticResource GlassBorder}" BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource GlassBorderHover}"/>
                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverFill}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="8" Padding="10,0"
                    Background="{StaticResource SoftFill}"
                    BorderBrush="{StaticResource GlassBorder}" BorderThickness="1">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="BorderBrush" Value="#99EF4444"/>
                <Setter TargetName="bd" Property="Background" Value="#24EF4444"/>
                <Setter Property="Foreground" Value="{StaticResource DangerText}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Search TextBox ═══════════ -->
    <Style x:Key="SearchBox" TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="CaretBrush" Value="{StaticResource AccentLight}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <ScrollViewer x:Name="PART_ContentHost"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Dark date input: keep the sidebar controls inside the viewer surface. -->
    <Style x:Key="DarkDatePicker" TargetType="DatePicker">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
      <Setter Property="Background" Value="{StaticResource BgTertiary}"/>
      <Setter Property="BorderBrush" Value="{StaticResource GlassBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FontSize" Value="11.5"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="DatePicker">
            <Grid>
              <Border x:Name="InputBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                  </Grid.ColumnDefinitions>
                  <DatePickerTextBox x:Name="PART_TextBox" Grid.Column="0" Padding="7,0,3,0" Background="Transparent" BorderThickness="0" Foreground="{TemplateBinding Foreground}" CaretBrush="{StaticResource AccentLight}" VerticalContentAlignment="Center"/>
                  <Button x:Name="PART_Button" Grid.Column="1" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" Focusable="False" ToolTip="Open calendar">
                    <Path Data="M4,6 h16 v14 h-16 z M4,10 h16 M8,3 v6 M16,3 v6" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.35" Stretch="Uniform" Width="14" Height="14"/>
                  </Button>
                </Grid>
              </Border>
              <Popup x:Name="PART_Popup" Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                <Border Background="{StaticResource BgElevated}" BorderBrush="{StaticResource GlassBorderHover}" BorderThickness="1" CornerRadius="8" Padding="4" SnapsToDevicePixels="True">
                  <Calendar x:Name="PART_Calendar" Background="{StaticResource BgElevated}" Foreground="{StaticResource TextPrimary}" BorderBrush="{StaticResource GlassBorder}"/>
                </Border>
              </Popup>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource GlassBorderHover}"/>
                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource BgElevated}"/>
              </Trigger>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource AccentLight}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="InputBorder" Property="Opacity" Value="0.42"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Resources>
        <Style TargetType="DatePickerTextBox">
          <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
          <Setter Property="CaretBrush" Value="{StaticResource AccentLight}"/>
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="DatePickerTextBox">
                <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                  <ScrollViewer x:Name="PART_ContentHost" VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                </Border>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
        <Style TargetType="CalendarDayButton">
          <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="BorderBrush" Value="Transparent"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="CalendarDayButton">
                <Border x:Name="Day" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="1">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Day" Property="Background" Value="{StaticResource HoverFill}"/></Trigger>
                  <Trigger Property="IsSelected" Value="True"><Setter TargetName="Day" Property="Background" Value="{StaticResource Accent}"/><Setter Property="Foreground" Value="White"/></Trigger>
                  <Trigger Property="IsToday" Value="True"><Setter TargetName="Day" Property="BorderBrush" Value="{StaticResource AccentLight}"/></Trigger>
                  <Trigger Property="IsInactive" Value="True"><Setter Property="Foreground" Value="{StaticResource TextTertiary}"/></Trigger>
                  <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.38"/></Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
        <Style TargetType="CalendarButton">
          <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
          <Setter Property="Background" Value="Transparent"/>
          <Setter Property="BorderBrush" Value="Transparent"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="CalendarButton">
                <Border x:Name="CalendarButtonBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4" Margin="1">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                  <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CalendarButtonBorder" Property="Background" Value="{StaticResource HoverFill}"/></Trigger>
                  <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.38"/></Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </Style.Resources>
    </Style>

    <!-- ═══════════ Favorite stepper buttons ═══════════ -->
    <Style x:Key="StepButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource FavoriteText}"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="#1AF43F5E">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#38F43F5E"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Image card (ListBoxItem) ═══════════ -->
    <Style x:Key="CardItem" TargetType="ListBoxItem">
      <Setter Property="Margin" Value="0,0,14,14"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="ring" CornerRadius="13" Padding="2" Background="Transparent"
                    RenderTransformOrigin="0.5,0.5">
              <Grid>
                <Border CornerRadius="12" ClipToBounds="True" Background="{StaticResource BgSecondary}"
                        Width="{Binding CardWidth}" Height="{Binding CardHeight}">
                  <Grid>
                    <Rectangle Fill="{Binding ArtBase}"/>
                    <Rectangle Fill="{Binding ArtGlow}"/>
                    <Image Source="{Binding Thumbnail}" Stretch="{Binding CardThumbnailStretch}" RenderOptions.BitmapScalingMode="HighQuality"/>

                    <!-- unseen dot -->
                    <Ellipse Width="8" Height="8" Margin="8" HorizontalAlignment="Left" VerticalAlignment="Top"
                             Fill="{StaticResource AccentLight}"
                             Visibility="{Binding ShowUnseenDot, Converter={StaticResource BoolToVis}}"/>

                    <!-- favorite count pill -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="7"
                            CornerRadius="999" Background="#9E000000" BorderBrush="#73F43F5E" BorderThickness="1"
                            Padding="6,2" Visibility="{Binding Fav, Converter={StaticResource CountToVis}}">
                      <StackPanel Orientation="Horizontal">
                        <Path Data="M12,21 C-4,10 3,-2 12,5 C21,-2 28,10 12,21 z" Fill="{StaticResource Favorite}"
                              Stretch="Uniform" Width="10" Height="10" Margin="0,0,3,0"/>
                        <TextBlock Text="{Binding Fav}" Foreground="{StaticResource FavoriteText}" FontSize="10.5" FontWeight="Bold"/>
                      </StackPanel>
                    </Border>

                    <!-- hover overlay + filename -->
                    <Border x:Name="overlay" VerticalAlignment="Bottom" Height="90" Opacity="0" Padding="10,0,10,10">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                          <GradientStop Color="#B8000000" Offset="0"/>
                          <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                      </Border.Background>
                      <TextBlock Text="{Binding FileName}" VerticalAlignment="Bottom" Foreground="#EAFFFFFF"
                                 FontSize="12" TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <!-- Status borders stay above hover chrome and bind to the tile's existing O(1) state. -->
                    <Border CornerRadius="11" BorderBrush="{DynamicResource EnhancedThumbnailStatusBorderBrush}" BorderThickness="3"
                            IsHitTestVisible="False" Visibility="{Binding Enhanced, Converter={StaticResource BoolToVis}}"/>
                    <Border CornerRadius="8" Margin="4" BorderBrush="{DynamicResource FavoriteThumbnailStatusBorderBrush}" BorderThickness="2"
                            IsHitTestVisible="False" Visibility="{Binding Fav, Converter={StaticResource CountToVis}}"/>
                  </Grid>
                </Border>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="overlay" Property="Opacity" Value="1"/>
                <Setter TargetName="ring" Property="RenderTransform">
                  <Setter.Value>
                    <TranslateTransform Y="-2"/>
                  </Setter.Value>
                </Setter>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ring" Property="Background" Value="{StaticResource AccentLight}"/>
                <Setter TargetName="overlay" Property="Opacity" Value="1"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ List-view row ═══════════ -->
    <Style x:Key="ListRowItem" TargetType="ListBoxItem">
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border x:Name="bd" Padding="14,8" Background="Transparent" BorderBrush="Transparent" BorderThickness="2,0,0,0">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="{Binding ListThumbnailWidth}" Height="{Binding ListThumbnailHeight}" CornerRadius="7" ClipToBounds="True" Margin="0,0,12,0">
                  <Grid>
                    <Rectangle Fill="{Binding ArtBase}"/>
                    <Rectangle Fill="{Binding ArtGlow}"/>
                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                    <Border CornerRadius="6" BorderBrush="{DynamicResource EnhancedThumbnailStatusBorderBrush}" BorderThickness="3"
                            IsHitTestVisible="False" Visibility="{Binding Enhanced, Converter={StaticResource BoolToVis}}"/>
                    <Border CornerRadius="4" Margin="4" BorderBrush="{DynamicResource FavoriteThumbnailStatusBorderBrush}" BorderThickness="2"
                            IsHitTestVisible="False" Visibility="{Binding Fav, Converter={StaticResource CountToVis}}"/>
                    <Ellipse Width="8" Height="8" Margin="7" HorizontalAlignment="Left" VerticalAlignment="Top" Fill="{StaticResource AccentLight}" Visibility="{Binding ShowUnseenDot, Converter={StaticResource BoolToVis}}"/>
                  </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding FileName}" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextTertiary}" FontSize="10.5" FontFamily="{StaticResource MonoFont}" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                  <TextBlock Text="{Binding Prompt}" Foreground="{StaticResource TextSecondary}" FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="999" Background="#9E000000" BorderBrush="#73F43F5E" BorderThickness="1"
                        Padding="7,2" Visibility="{Binding Fav, Converter={StaticResource CountToVis}}">
                  <StackPanel Orientation="Horizontal">
                    <Path Data="M12,21 C-4,10 3,-2 12,5 C21,-2 28,10 12,21 z" Fill="{StaticResource Favorite}" Stretch="Uniform" Width="10" Height="10" Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding Fav}" Foreground="{StaticResource FavoriteText}" FontSize="10.5" FontWeight="Bold"/>
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#08FFFFFF"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentSoft}"/>
                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Landing primary/browse buttons ═══════════ -->
    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Height" Value="50"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="12" Padding="26,0" Background="{StaticResource Accent}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentLight}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="BrowseButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
      <Setter Property="FontWeight" Value="Medium"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="12" Padding="20,0" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ContentPresenter/>
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgElevated}"/>
                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource GlassBorderHover}"/>
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DangerFilled" TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" CornerRadius="10" Padding="18,0" Background="{StaticResource Danger}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="#F87171"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ═══════════ Slim dark scrollbars ═══════════ -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
      <Setter Property="OverridesDefaultStyle" Value="True"/>
      <Setter Property="IsTabStop" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="t" CornerRadius="4" Background="#22FFFFFF" Margin="2"/>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="t" Property="Background" Value="#3CFFFFFF"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ScrollHidden" TargetType="RepeatButton">
      <Setter Property="OverridesDefaultStyle" Value="True"/>
      <Setter Property="Focusable" Value="False"/>
      <Setter Property="IsTabStop" Value="False"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Width" Value="10"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ScrollBar">
            <Grid Background="Transparent">
              <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.Thumb><Thumb Style="{StaticResource ScrollThumb}" MinHeight="28"/></Track.Thumb>
                <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource ScrollHidden}" Command="ScrollBar.PageDownCommand"/></Track.IncreaseRepeatButton>
                <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource ScrollHidden}" Command="ScrollBar.PageUpCommand"/></Track.DecreaseRepeatButton>
              </Track>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Width" Value="Auto"/>
          <Setter Property="Height" Value="10"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="ScrollBar">
                <Grid Background="Transparent">
                  <Track x:Name="PART_Track">
                    <Track.Thumb><Thumb Style="{StaticResource ScrollThumb}" MinWidth="28"/></Track.Thumb>
                    <Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource ScrollHidden}" Command="ScrollBar.PageRightCommand"/></Track.IncreaseRepeatButton>
                    <Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource ScrollHidden}" Command="ScrollBar.PageLeftCommand"/></Track.DecreaseRepeatButton>
                  </Track>
                </Grid>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Trigger>
      </Style.Triggers>
    </Style>

  </Application.Resources>
</Application>
