<Window x:Class="PhotoViewer.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PhotoViewer.Wpf"
        Title="PhotoViewer" Height="820" Width="1280" MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgPrimary}" Foreground="{StaticResource TextPrimary}"
        FontFamily="Segoe UI" TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

  <WindowChrome.WindowChrome>
    <WindowChrome CaptionHeight="52" ResizeBorderThickness="6" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
  </WindowChrome.WindowChrome>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="40"/>
    </Grid.RowDefinitions>

    <!-- ═══════════════ Header ═══════════════ -->
    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,0,0,1">
      <Grid Margin="14,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- left cluster -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="ToggleSidebar" Style="{StaticResource IconButtonActive}" Click="ToggleSidebar_Click"
                  ToolTip="Hide sidebar" WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Data="M3,4 h18 v16 h-18 z M9,4 v16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Stretch="Uniform" Width="18" Height="18"/>
          </Button>
          <TextBlock Text="PhotoViewer" FontSize="18.5" FontWeight="Bold" Margin="8,0,4,0" VerticalAlignment="Center" Cursor="Hand"
                     Foreground="{StaticResource LogoBrush}" WindowChrome.IsHitTestVisibleInChrome="True"
                     MouseLeftButtonUp="Logo_Click" ToolTip="Back to folder selection"/>
          <Button Style="{StaticResource IconButton}" ToolTip="Refresh active folder" Click="RefreshActiveFolder_Click" WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Data="M22,11 a10,10 0 1 1 -3,-7 M22,4 v5 h-5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Stretch="Uniform" Width="17" Height="17"/>
          </Button>
        </StackPanel>

        <!-- search -->
        <Border Grid.Column="1" Height="40" MaxWidth="720" HorizontalAlignment="Stretch" Margin="10,0"
                CornerRadius="999" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1"
                WindowChrome.IsHitTestVisibleInChrome="True">
          <DockPanel Margin="12,0,10,0" LastChildFill="True">
            <Path DockPanel.Dock="Left" Data="M11,11 m-8,0 a8,8 0 1 0 16,0 a8,8 0 1 0 -16,0 M21,21 l-4.3,-4.3" Stroke="{StaticResource TextTertiary}" StrokeThickness="1.8" Stretch="Uniform" Width="15" Height="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBox Style="{StaticResource SearchBox}" x:Name="SearchInput" FontSize="13" VerticalAlignment="Center" TextChanged="SearchInput_TextChanged"/>
          </DockPanel>
        </Border>

        <!-- right cluster -->
        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Style="{StaticResource IconButton}" Foreground="#6EE7B7" ToolTip="Album mutation is deferred" IsEnabled="False" Opacity="0.45" WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Data="M12,5 v14 M5,12 h14" Stroke="#6EE7B7" StrokeThickness="2" Stretch="Uniform" Width="17" Height="17"/>
          </Button>
          <TextBlock x:Name="HeaderStats" Text="3 selected · 12,480 images · 4 folders" Foreground="{StaticResource TextTertiary}" FontSize="12" Margin="6,0,8,0" VerticalAlignment="Center"/>
          <Button x:Name="ToggleRight" Style="{StaticResource IconButtonActive}" Click="ToggleRight_Click" ToolTip="Hide right panel" WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Data="M3,4 h18 v16 h-18 z M15,4 v16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Stretch="Uniform" Width="18" Height="18"/>
          </Button>
          <Rectangle Width="1" Height="22" Fill="{StaticResource GlassBorder}" Margin="8,0"/>

          <!-- window caption buttons -->
          <Button Style="{StaticResource CaptionButton}" Click="Minimize_Click" ToolTip="Minimize" WindowChrome.IsHitTestVisibleInChrome="True">
            <Rectangle Width="11" Height="1.4" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
          </Button>
          <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Click="Maximize_Click" ToolTip="Maximize" WindowChrome.IsHitTestVisibleInChrome="True">
            <Rectangle Width="11" Height="11" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.4" Fill="Transparent"/>
          </Button>
          <Button Style="{StaticResource CloseButton}" Click="Close_Click" ToolTip="Close" WindowChrome.IsHitTestVisibleInChrome="True">
            <Path Data="M2,2 L12,12 M12,2 L2,12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.4" Width="12" Height="12" Stretch="Uniform"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══════════════ Body ═══════════════ -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="SidebarCol" Width="240"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition x:Name="RightCol" Width="340"/>
      </Grid.ColumnDefinitions>

      <!-- ─────── Sidebar ─────── -->
      <Border Grid.Column="0" x:Name="Sidebar" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
          <StackPanel>

            <!-- Folder -->
            <Border Padding="16,14,16,12" BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,1">
              <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                  <Path Data="M22,19 a2,2 0 0 1 -2,2 H4 a2,2 0 0 1 -2,-2 V5 a2,2 0 0 1 2,-2 h5 l2,3 h9 a2,2 0 0 1 2,2 z" Stroke="{StaticResource TextTertiary}" StrokeThickness="1.8" Stretch="Uniform" Width="14" Height="14" Margin="0,0,6,0"/>
                  <TextBlock Text="FOLDER" Style="{StaticResource SectionHeader}"/>
                </StackPanel>
                <TextBlock x:Name="FolderPathText" Text="D:\SD\outputs  (+3)" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" Margin="0,0,0,3"/>
                <TextBlock x:Name="FolderCountText" Text="12,480 images indexed" Foreground="{StaticResource TextTertiary}" FontSize="11.5" Margin="0,0,0,7"/>
                <StackPanel Orientation="Horizontal">
                  <Button Style="{StaticResource SidebarLink}" Content="Add folder" Margin="0,0,14,0" Click="OpenFolder_Click"/>
                  <Button Style="{StaticResource SidebarLink}" Content="Change folder" Click="OpenFolder_Click"/>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Filters -->
            <Border Padding="16,14,16,12" BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,1">
              <StackPanel>
                <TextBlock Text="FILTERS" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <CheckBox x:Name="FavoriteOnlyFilter" Content="Favorites only" Foreground="{StaticResource TextSecondary}" FontSize="12.5" Margin="0,0,0,6" Checked="FavoriteFilter_Changed" Unchecked="FavoriteFilter_Changed"/>
                <CheckBox x:Name="UnfavoriteOnlyFilter" Content="Unrated only" Foreground="{StaticResource TextSecondary}" FontSize="12.5" Margin="0,0,0,6" Checked="FavoriteFilter_Changed" Unchecked="FavoriteFilter_Changed"/>
                <WrapPanel x:Name="FavoriteLevelFilterPanel" Margin="0,0,0,6">
                  <WrapPanel.Resources><Style TargetType="CheckBox" BasedOn="{StaticResource Pill}"><Setter Property="Margin" Value="0,0,6,0"/></Style></WrapPanel.Resources>
                  <CheckBox x:Name="FavoriteLevel1Filter" Content="Lv 1" Checked="FavoriteLevelFilter_Changed" Unchecked="FavoriteLevelFilter_Changed"/>
                  <CheckBox x:Name="FavoriteLevel2Filter" Content="Lv 2" Checked="FavoriteLevelFilter_Changed" Unchecked="FavoriteLevelFilter_Changed"/>
                  <CheckBox x:Name="FavoriteLevel3Filter" Content="Lv 3" Checked="FavoriteLevelFilter_Changed" Unchecked="FavoriteLevelFilter_Changed"/>
                  <CheckBox x:Name="FavoriteLevel4Filter" Content="Lv 4" Checked="FavoriteLevelFilter_Changed" Unchecked="FavoriteLevelFilter_Changed"/>
                  <CheckBox x:Name="FavoriteLevel5Filter" Content="Lv 5" Checked="FavoriteLevelFilter_Changed" Unchecked="FavoriteLevelFilter_Changed"/>
                </WrapPanel>
                <TextBlock x:Name="FavoriteFilterSummary" Text="All ratings" Foreground="{StaticResource TextTertiary}" FontSize="11.5" Margin="0,0,0,6"/>
                <CheckBox x:Name="EnhancedOnlyFilter" Content="Enhanced only" Foreground="{StaticResource TextSecondary}" FontSize="12.5" Margin="0,0,0,6" Checked="Filter_Changed" Unchecked="Filter_Changed" ToolTip="Read-only filter from .cache/enhance/jobs.json"/>
                <CheckBox x:Name="UnseenOnlyFilter" Content="Unseen only" Foreground="{StaticResource TextSecondary}" FontSize="12.5" Margin="0,0,0,8" Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <CheckBox x:Name="ShowUnseenDots" Content="Unseen dots" Foreground="{StaticResource TextSecondary}" FontSize="12.5" Margin="0,0,0,8" Checked="ShowUnseenDots_Changed" Unchecked="ShowUnseenDots_Changed"/>
                <TextBlock Text="DATE" Foreground="{StaticResource TextTertiary}" FontSize="9.5" FontWeight="Bold" Margin="0,0,0,4"/>
                <Grid Margin="0,2,0,4">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="From" Foreground="{StaticResource TextTertiary}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,6,4"/>
                  <DatePicker x:Name="DateFromInput" Grid.Row="0" Grid.Column="1" Height="26" Margin="0,0,0,4" SelectedDateFormat="Short" SelectedDateChanged="ManualDateRange_Changed"/>
                  <TextBlock Grid.Row="1" Grid.Column="0" Text="To" Foreground="{StaticResource TextTertiary}" FontSize="11.5" VerticalAlignment="Center" Margin="0,0,6,0"/>
                  <DatePicker x:Name="DateToInput" Grid.Row="1" Grid.Column="1" Height="26" SelectedDateFormat="Short" SelectedDateChanged="ManualDateRange_Changed"/>
                </Grid>
                <TextBlock x:Name="DateFilterSummary" Text="No date filter" Foreground="{StaticResource TextTertiary}" FontSize="11.5" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Folders -->
            <Border Padding="16,14,16,12" BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,1">
              <StackPanel>
                <Button x:Name="FoldersSectionToggle" Style="{StaticResource SidebarLink}" Click="ToggleFoldersSection_Click" HorizontalAlignment="Left" Margin="0,0,0,8"><StackPanel Orientation="Horizontal"><TextBlock Text="FOLDERS" Style="{StaticResource SectionHeader}"/><TextBlock x:Name="FoldersSectionToggleText" Text="−" Margin="8,0,0,0"/></StackPanel></Button>
                <StackPanel x:Name="FoldersSectionContent">
                <WrapPanel Margin="0,0,0,8">
                  <Button Style="{StaticResource SidebarLink}" Content="Show all" Margin="0,0,12,0" Click="ShowAllFolderBuckets_Click"/>
                  <Button Style="{StaticResource SidebarLink}" Content="Hide all" Margin="0,0,12,0" Click="HideAllFolderBuckets_Click"/>
                  <Button Style="{StaticResource SidebarLink}" Content="Invert" Click="InvertFolderBuckets_Click"/>
                </WrapPanel>
                <TextBlock x:Name="FolderBucketStatusText" Text="No folder buckets loaded" Foreground="{StaticResource TextTertiary}" FontSize="11.5" Margin="0,0,0,6" TextWrapping="Wrap"/>
                <ItemsControl x:Name="SidebarFolderSetList" MaxHeight="180">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border CornerRadius="8" Background="{StaticResource SoftFill}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="7,5" Margin="0,0,0,4" Opacity="{Binding Opacity}">
                        <Grid>
                          <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                          <StackPanel Grid.Column="0">
                            <DockPanel>
                              <TextBlock DockPanel.Dock="Right" Text="{Binding CountText}" Foreground="{StaticResource TextTertiary}" FontSize="10.5" Margin="8,0,0,0"/>
                              <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextSecondary}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                            <TextBlock Text="{Binding Path}" Foreground="{StaticResource TextTertiary}" FontSize="10.5" TextTrimming="CharacterEllipsis"/>
                          </StackPanel>
                          <Button Grid.Column="1" Style="{StaticResource SidebarLink}" Content="{Binding VisibilityText}" Tag="{Binding}" Click="ToggleFolderBucket_Click" Margin="8,0,0,0"/>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                </StackPanel>
              </StackPanel>
            </Border>

            <!-- Sort -->
            <Border Padding="16,14,16,12" BorderBrush="#0AFFFFFF" BorderThickness="0,0,0,1">
              <StackPanel>
                <TextBlock Text="SORT" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                <Border CornerRadius="8" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="3">
                  <UniformGrid Rows="6">
                    <RadioButton x:Name="SortModifiedNewest" Style="{StaticResource Seg}" GroupName="sort" Content="Modified new" IsChecked="True" Checked="SortModifiedNewest_Checked"/>
                    <RadioButton x:Name="SortModifiedOldest" Style="{StaticResource Seg}" GroupName="sort" Content="Modified old" Checked="SortModifiedOldest_Checked"/>
                    <RadioButton x:Name="SortCreatedNewest" Style="{StaticResource Seg}" GroupName="sort" Content="Created new" Checked="SortCreatedNewest_Checked"/>
                    <RadioButton x:Name="SortCreatedOldest" Style="{StaticResource Seg}" GroupName="sort" Content="Created old" Checked="SortCreatedOldest_Checked"/>
                    <RadioButton x:Name="SortName" Style="{StaticResource Seg}" GroupName="sort" Content="Name" Checked="SortName_Checked"/>
                    <RadioButton x:Name="SortRandom" Style="{StaticResource Seg}" GroupName="sort" Content="Random" Checked="SortRandom_Checked"/>
                  </UniformGrid>
                </Border>
                <Button x:Name="ReshuffleSortButton" Style="{StaticResource SidebarLink}" Content="Reshuffle" Click="ReshuffleSort_Click" Margin="2,8,0,0" HorizontalAlignment="Left"/>
              </StackPanel>
            </Border>

            <!-- Display -->
            <Border Padding="16,14,16,16">
              <StackPanel>
                <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeader}" Margin="0,0,0,10"/>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Mode" Foreground="{StaticResource TextTertiary}" FontSize="11.5" VerticalAlignment="Center"/>
                  <Border Grid.Column="1" CornerRadius="8" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="3">
                    <UniformGrid Rows="1">
                      <RadioButton x:Name="ModeGrid" Style="{StaticResource Seg}" GroupName="mode" Content="Grid" IsChecked="True" Checked="ModeGrid_Checked"/>
                      <RadioButton x:Name="ModeList" Style="{StaticResource Seg}" GroupName="mode" Content="List" Checked="ModeList_Checked"/>
                    </UniformGrid>
                  </Border>
                </Grid>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Style" Foreground="{StaticResource TextTertiary}" FontSize="11.5" VerticalAlignment="Center"/>
                  <Border Grid.Column="1" CornerRadius="8" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="3">
                    <UniformGrid Rows="1">
                      <RadioButton x:Name="StyleStandard" Style="{StaticResource Seg}" GroupName="style" Content="Standard" IsChecked="True" Checked="StyleStandard_Checked"/>
                      <RadioButton x:Name="StyleCompact" Style="{StaticResource Seg}" GroupName="style" Content="Compact" Checked="StyleCompact_Checked"/>
                      <RadioButton x:Name="StylePoster" Style="{StaticResource Seg}" GroupName="style" Content="Poster" Checked="StylePoster_Checked"/>
                    </UniformGrid>
                  </Border>
                </Grid>
                <Grid Margin="0,0,0,10">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Aspect" Foreground="{StaticResource TextTertiary}" FontSize="11.5" VerticalAlignment="Center"/>
                  <Border Grid.Column="1" CornerRadius="8" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="3">
                    <UniformGrid Rows="1">
                      <RadioButton x:Name="AspectOriginalButton" Style="{StaticResource Seg}" GroupName="aspect" Content="Original" IsChecked="True" Checked="AspectOriginal_Checked"/>
                      <RadioButton x:Name="AspectSquareButton" Style="{StaticResource Seg}" GroupName="aspect" Content="1:1" Checked="AspectSquare_Checked"/>
                      <RadioButton x:Name="AspectPortraitButton" Style="{StaticResource Seg}" GroupName="aspect" Content="2:3" Checked="AspectPortrait_Checked"/>
                    </UniformGrid>
                  </Border>
                </Grid>
                <Grid>
                  <Grid.ColumnDefinitions><ColumnDefinition Width="46"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="Size" Foreground="{StaticResource TextTertiary}" FontSize="11.5" VerticalAlignment="Center"/>
                  <Button Grid.Column="1" Style="{StaticResource StepButton}" Content="-" ToolTip="Zoom out" Click="ZoomOut_Click" Margin="0,0,5,0"/>
                  <Slider Grid.Column="2" x:Name="SizeSlider" Minimum="40" Maximum="600" Value="200" VerticalAlignment="Center" ValueChanged="SizeSlider_ValueChanged"/>
                  <Button Grid.Column="3" Style="{StaticResource StepButton}" Content="0" ToolTip="Reset zoom" Click="ZoomReset_Click" Margin="5,0,5,0"/>
                  <Button Grid.Column="4" Style="{StaticResource StepButton}" Content="+" ToolTip="Zoom in" Click="ZoomIn_Click"/>
                </Grid>
              </StackPanel>
            </Border>

          </StackPanel>
        </ScrollViewer>
      </Border>

      <!-- ─────── Main grid ─────── -->
      <Border Grid.Column="1" Background="{StaticResource BgPrimary}">
       <Grid>
        <ListBox x:Name="CardsList" Background="Transparent" BorderThickness="0" Padding="20,16,12,24"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ItemContainerStyle="{StaticResource CardItem}" SelectionMode="Extended" SelectionChanged="CardsList_SelectionChanged">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <DockPanel Margin="2,16,10,10">
                    <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" Foreground="#D1FFFFFF" FontSize="14.5" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Left" Text="{Binding ItemCount, StringFormat=' ·  {0} images'}" Foreground="{StaticResource TextTertiary}" FontSize="11.5" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <Rectangle Height="1" VerticalAlignment="Center" Margin="12,0,0,0">
                      <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                          <GradientStop Color="#57FFFFFF" Offset="0"/>
                          <GradientStop Color="#0AFFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                      </Rectangle.Fill>
                    </Rectangle>
                  </DockPanel>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ListBox.GroupStyle>
        </ListBox>

        <!-- List mode -->
        <ListBox x:Name="RowsList" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="8,8,4,24"
                 ItemContainerStyle="{StaticResource ListRowItem}" SelectionMode="Extended" SelectionChanged="CardsList_SelectionChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True"
                 VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
          <ListBox.ItemsPanel><ItemsPanelTemplate><VirtualizingStackPanel/></ItemsPanelTemplate></ListBox.ItemsPanel>
          <ListBox.GroupStyle>
            <GroupStyle>
              <GroupStyle.HeaderTemplate>
                <DataTemplate>
                  <DockPanel Margin="14,14,14,4">
                    <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" Foreground="#B8FFFFFF" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Rectangle Height="1" VerticalAlignment="Center" Margin="12,0,0,0">
                      <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                          <GradientStop Color="#3CFFFFFF" Offset="0"/>
                          <GradientStop Color="#0AFFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                      </Rectangle.Fill>
                    </Rectangle>
                  </DockPanel>
                </DataTemplate>
              </GroupStyle.HeaderTemplate>
            </GroupStyle>
          </ListBox.GroupStyle>
        </ListBox>
       </Grid>
      </Border>

      <!-- ─────── Right preview ─────── -->
      <Border Grid.Column="2" x:Name="RightPanel" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1,0,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <!-- preview label -->
          <DockPanel Grid.Row="0" LastChildFill="True">
            <Border DockPanel.Dock="Left" Background="{StaticResource AccentGlass}" Padding="12,0" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,0,1,0">
              <TextBlock x:Name="PreviewTabName" Text="00427-portrait.png" Foreground="{StaticResource TextPrimary}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
            </Border>
            <TextBlock Text="Preview" Foreground="{StaticResource TextTertiary}" FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>
          </DockPanel>

          <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14">
              <!-- image -->
              <Border CornerRadius="12" ClipToBounds="True" Cursor="Hand" MouseLeftButtonUp="PreviewImage_Click" Margin="0,0,0,12">
                <Border.Effect><DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.5" Color="Black"/></Border.Effect>
                <Grid Height="380">
                  <Rectangle x:Name="PreviewArtBase"/>
                  <Rectangle x:Name="PreviewArtGlow"/>
                  <Image x:Name="PreviewBitmap" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
              </Border>

              <!-- actions -->
              <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" CornerRadius="8" ClipToBounds="True" BorderBrush="#66F43F5E" BorderThickness="1" Margin="0,0,8,0">
                  <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource StepButton}" Content="−" ToolTip="Decrease (X)" Click="FavoriteDecrease_Click"/>
                    <Border Width="38" Background="#1AF43F5E">
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="FavoriteLevelText" Text="0" Foreground="{StaticResource FavoriteText}" FontWeight="Bold" FontSize="13"/>
                        <Path Data="M12,21 C-4,10 3,-2 12,5 C21,-2 28,10 12,21 z" Fill="{StaticResource Favorite}" Stretch="Uniform" Width="11" Height="11" Margin="2,0,0,0"/>
                      </StackPanel>
                    </Border>
                    <Button Style="{StaticResource StepButton}" Content="+" ToolTip="Increase" Click="FavoriteIncrease_Click"/>
                  </StackPanel>
                </Border>
                <Button Grid.Column="1" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="OpenSelectedExternally_Click">
                  <StackPanel Orientation="Horizontal">
                    <Path Data="M18,13 v6 a2,2 0 0 1 -2,2 H5 a2,2 0 0 1 -2,-2 V8 a2,2 0 0 1 2,-2 h6 M15,3 h6 v6 M10,14 L21,3" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Stretch="Uniform" Width="14" Height="14" Margin="0,0,5,0"/>
                    <TextBlock Text="Open"/>
                  </StackPanel>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource GhostButton}" Width="52" Margin="0,0,8,0" ToolTip="Open selected preview tab" Click="OpenSelectedPreviewTab_Click">
                  <TextBlock Text="Tab"/>
                </Button>
                <Button Grid.Column="3" Style="{StaticResource DangerButton}" Width="40" ToolTip="Delete/recycle is deferred" IsEnabled="False" Opacity="0.45">
                  <Path Data="M3,6 h18 M8,6 V4 a2,2 0 0 1 2,-2 h4 a2,2 0 0 1 2,2 v2 M19,6 l-1,14 a2,2 0 0 1 -2,2 H8 a2,2 0 0 1 -2,-2 L5,6" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Stretch="Uniform" Width="14" Height="14"/>
                </Button>
              </Grid>

              <!-- metadata -->
              <TextBlock x:Name="PreviewFileName" Text="00427-portrait.png" Foreground="{StaticResource TextPrimary}" FontSize="13.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>
              <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.Resources>
                  <Style TargetType="TextBlock">
                    <Setter Property="Margin" Value="0,2"/>
                    <Setter Property="FontSize" Value="12.5"/>
                  </Style>
                </Grid.Resources>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="SIZE" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                <TextBlock x:Name="PreviewSizeText" Grid.Row="0" Grid.Column="1" Text="832 x 1216" Foreground="{StaticResource TextSecondary}" Margin="12,2,0,2"/>
                <TextBlock x:Name="PreviewModelLabel" Grid.Row="1" Grid.Column="0" Text="MODEL" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                <TextBlock x:Name="PreviewModelText" Grid.Row="1" Grid.Column="1" Text="animagineXL_v31" Foreground="{StaticResource TextSecondary}" Margin="12,2,0,2"/>
                <TextBlock x:Name="PreviewSamplerLabel" Grid.Row="2" Grid.Column="0" Text="SAMPLER" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                <TextBlock x:Name="PreviewSamplerText" Grid.Row="2" Grid.Column="1" Text="Euler a" Foreground="{StaticResource TextSecondary}" Margin="12,2,0,2"/>
                <TextBlock x:Name="PreviewStepsLabel" Grid.Row="3" Grid.Column="0" Text="STEPS" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                <TextBlock x:Name="PreviewStepsText" Grid.Row="3" Grid.Column="1" Text="28" Foreground="{StaticResource TextSecondary}" Margin="12,2,0,2"/>
                <TextBlock x:Name="PreviewCfgLabel" Grid.Row="4" Grid.Column="0" Text="CFG" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                <TextBlock x:Name="PreviewCfgText" Grid.Row="4" Grid.Column="1" Text="6.5" Foreground="{StaticResource TextSecondary}" Margin="12,2,0,2"/>
                <TextBlock x:Name="PreviewSeedLabel" Grid.Row="5" Grid.Column="0" Text="SEED" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                <TextBlock x:Name="PreviewSeedText" Grid.Row="5" Grid.Column="1" Text="3874219055" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource MonoFont}" FontSize="12" Margin="12,2,0,2"/>
                <TextBlock Grid.Row="6" Grid.Column="0" Text="DATE" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
                <TextBlock x:Name="PreviewDateText" Grid.Row="6" Grid.Column="1" Text="2026-07-08 14:22" Foreground="{StaticResource TextSecondary}" Margin="12,2,0,2"/>
              </Grid>

              <DockPanel Margin="0,12,0,4" LastChildFill="True">
                <Button x:Name="CopyPreviewPromptButton" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Height="24" MinWidth="52" Padding="8,2" Margin="6,0,0,0" Content="Copy" IsEnabled="False" ToolTip="No prompt metadata loaded" Click="CopyPreviewPrompt_Click"/>
                <Button x:Name="CopyPreviewMetadataButton" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Height="24" MinWidth="52" Padding="8,2" Content="Copy" IsEnabled="False" ToolTip="No PNG metadata loaded" Click="CopyPreviewMetadata_Click"/>
                <TextBlock x:Name="PreviewPromptLabel" Text="PROMPT" Foreground="{StaticResource TextTertiary}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </DockPanel>
              <Border CornerRadius="8" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="10,8">
                <TextBlock x:Name="PreviewPromptText" Text="masterpiece, best quality, 1girl, portrait, silver hair, intricate detail, soft rim lighting, cinematic, depth of field, looking at viewer, ornate jacket, snowy background" Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
              </Border>

              <DockPanel Margin="0,10,0,4" LastChildFill="True">
                <Button x:Name="CopyPreviewNegativeButton" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Height="24" MinWidth="52" Padding="8,2" Content="Copy" IsEnabled="False" ToolTip="No negative prompt metadata loaded" Click="CopyPreviewNegative_Click"/>
                <TextBlock x:Name="PreviewNegativeLabel" Text="NEGATIVE" Foreground="{StaticResource TextTertiary}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
              </DockPanel>
              <Border x:Name="PreviewNegativeCard" CornerRadius="8" Background="{StaticResource BgTertiary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="10,8">
                <TextBlock x:Name="PreviewNegativeText" Text="lowres, bad anatomy, bad hands, text, error, missing fingers, extra digit, worst quality, jpeg artifacts, watermark, signature" Foreground="#F5A5A5" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </Border>
    </Grid>

    <!-- ═══════════════ Bottom preview tabs ═══════════════ -->
    <Border Grid.Row="2" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,1,0,0">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
          <Button x:Name="RestorePreviewTabButton" Style="{StaticResource GhostButton}" Height="26" FontSize="11" Content="Reopen" Margin="0,0,6,0" ToolTip="Reopen last closed (Ctrl+Shift+T)" Click="RestorePreviewTab_Click"/>
          <Button x:Name="CloseAllPreviewTabsButton" Style="{StaticResource GhostButton}" Height="26" FontSize="11" Content="Close all" Click="CloseAllPreviewTabs_Click"/>
        </StackPanel>
        <Grid>
          <TextBlock x:Name="PreviewTabsEmptyText" Text="No preview tabs" Foreground="{StaticResource TextTertiary}" FontSize="12" VerticalAlignment="Center" Margin="8,0"/>
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="PreviewTabList">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Padding="6,0" BorderBrush="#0AFFFFFF" BorderThickness="0,0,1,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                       <Button Style="{StaticResource GhostButton}" Height="26" FontSize="11" Padding="8,0" Tag="{Binding}" Click="ActivatePreviewTab_Click" MouseEnter="PreviewTab_MouseEnter" MouseMove="PreviewTab_MouseMove" MouseLeave="PreviewTab_MouseLeave" ToolTip="{Binding Path}">
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="{Binding ActiveMarker}" Foreground="{StaticResource FavoriteText}" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"/>
                          <TextBlock Text="{Binding FileName}" Foreground="{Binding Foreground}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="160" VerticalAlignment="Center"/>
                        </StackPanel>
                       </Button>
                       <Button Style="{StaticResource GhostButton}" Width="26" Height="26" FontSize="11" Content="{Binding PinMarker}" Tag="{Binding}" Click="TogglePreviewTabPin_Click" ToolTip="{Binding PinToolTip}"/>
                       <Button Style="{StaticResource GhostButton}" Width="26" Height="26" FontSize="12" Content="x" Tag="{Binding}" Click="ClosePreviewTab_Click" ToolTip="Close tab"/>
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
          <Popup x:Name="PreviewTabHoverPopup" AllowsTransparency="True" Placement="Top" StaysOpen="True" VerticalOffset="-10">
            <Border Width="220" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorderHover}" BorderThickness="1" CornerRadius="10" Padding="10" IsHitTestVisible="False">
              <StackPanel>
                <Border Height="148" Background="{StaticResource BgTertiary}" CornerRadius="8" ClipToBounds="True" Margin="0,0,0,8">
                  <Image x:Name="PreviewTabHoverBitmap" Stretch="UniformToFill"/>
                </Border>
                <TextBlock x:Name="PreviewTabHoverName" Foreground="{StaticResource TextPrimary}" FontSize="12.5" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="PreviewTabHoverPath" Foreground="{StaticResource TextTertiary}" FontSize="10.5" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
              </StackPanel>
            </Border>
          </Popup>
        </Grid>
      </DockPanel>
    </Border>

    <!-- ═══════════════ Landing / scanning ═══════════════ -->
    <Grid x:Name="Landing" Grid.RowSpan="3" Visibility="Collapsed" Background="{StaticResource BgPrimary}">
      <Rectangle HorizontalAlignment="Left" Width="700" Height="520" VerticalAlignment="Center" Margin="-160,0,0,0">
        <Rectangle.Fill>
          <RadialGradientBrush><GradientStop Color="#1A6366F1" Offset="0"/><GradientStop Color="#006366F1" Offset="1"/></RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <Rectangle HorizontalAlignment="Right" Width="720" Height="520" VerticalAlignment="Center" Margin="0,0,-180,0">
        <Rectangle.Fill>
          <RadialGradientBrush><GradientStop Color="#14A855F7" Offset="0"/><GradientStop Color="#00A855F7" Offset="1"/></RadialGradientBrush>
        </Rectangle.Fill>
      </Rectangle>

      <StackPanel Width="760" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="PhotoViewer" FontSize="52" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource LogoBrush}"/>
        <TextBlock Text="Index and search Stable Diffusion PNG metadata locally" HorizontalAlignment="Center"
                   Foreground="{StaticResource TextSecondary}" FontSize="15" Margin="0,6,0,34"/>

        <!-- folder set panel -->
        <StackPanel x:Name="LandingPanel">
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource BrowseButton}" Margin="0,0,12,0" Click="OpenFolder_Click">
              <StackPanel Orientation="Horizontal">
                <Path Data="M22,19 a2,2 0 0 1 -2,2 H4 a2,2 0 0 1 -2,-2 V5 a2,2 0 0 1 2,-2 h5 l2,3 h9 a2,2 0 0 1 2,2 z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Stretch="Uniform" Width="17" Height="17" Margin="0,0,8,0"/>
                <TextBlock Text="Add folder" VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
            <Button Grid.Column="1" x:Name="OpenFolderSetButton" Style="{StaticResource PrimaryButton}" Content="Open folder set" Click="StartScan_Click"/>
          </Grid>

          <Border CornerRadius="8" Background="#09FFFFFF" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="12,9" Margin="0,0,0,6" Visibility="Collapsed">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="・" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock DockPanel.Dock="Right" Text="✕" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" Margin="8,0,0,0"/>
              <TextBlock Text="D:\SD\outputs\txt2img" Foreground="{StaticResource TextPrimary}" FontSize="13.5" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
          </Border>
          <Border CornerRadius="8" Background="#09FFFFFF" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="12,9" Margin="0,0,0,12" Visibility="Collapsed">
            <DockPanel>
              <TextBlock DockPanel.Dock="Left" Text="・" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" Margin="0,0,8,0"/>
              <TextBlock DockPanel.Dock="Right" Text="✕" Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center" Margin="8,0,0,0"/>
              <TextBlock Text="D:\SD\outputs\img2img" Foreground="{StaticResource TextPrimary}" FontSize="13.5" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
          </Border>

          <Border CornerRadius="8" Background="#09FFFFFF" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="8,7" Margin="0,0,0,12">
            <ItemsControl x:Name="LandingFolderSetList" MaxHeight="118">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <DockPanel Margin="0,0,0,5">
                    <Button DockPanel.Dock="Right" Style="{StaticResource StepButton}" Content="x" ToolTip="Remove folder" Tag="{Binding}" Click="RemoveLandingFolder_Click" Margin="8,0,0,0"/>
                    <TextBlock Text="{Binding}" Foreground="{StaticResource TextPrimary}" FontSize="13" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                  </DockPanel>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Border>

          <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Height="72" CornerRadius="12" Background="{StaticResource BgSecondary}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="10,7" Margin="0,0,12,0">
              <TextBlock Text="Paste one absolute path per line…" Foreground="{StaticResource TextTertiary}" FontSize="13"/>
            </Border>
            <TextBox Grid.Column="0" x:Name="PastedFoldersInput" Margin="10,7,22,7" AcceptsReturn="True" TextWrapping="NoWrap" BorderThickness="0" Background="{StaticResource BgSecondary}"
                     Foreground="{StaticResource TextPrimary}" FontSize="13" VerticalScrollBarVisibility="Auto"/>
            <Button Grid.Column="1" Style="{StaticResource BrowseButton}" Content="Add pasted" VerticalAlignment="Stretch" Click="AddPastedFolders_Click"/>
          </Grid>
          <TextBlock x:Name="LandingFolderStatusText" Text="No folders selected yet." Foreground="{StaticResource TextTertiary}" FontSize="12" Margin="2,8,0,0"/>
        </StackPanel>

        <Button Style="{StaticResource BrowseButton}" Height="46" HorizontalAlignment="Stretch" Margin="0,14,0,0" Click="OpenLastFolder_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="Open last folder set" Foreground="{StaticResource TextPrimary}" FontWeight="Medium"/>
            <TextBlock x:Name="LastFolderSetText" Text="  No saved folder set" Foreground="{StaticResource TextTertiary}" FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>
        </Button>

        <TextBlock Text="RECENT FOLDER SETS" Foreground="{StaticResource TextTertiary}" FontSize="10" FontWeight="SemiBold" Margin="2,20,0,8"/>
        <ItemsControl x:Name="RecentFolderSetList">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Style="{StaticResource GhostButton}" Height="30" Margin="0,0,7,7" FontSize="12" Tag="{Binding}" Click="RecentFolderSet_Click">
                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis" MaxWidth="220"/>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <WrapPanel Visibility="Collapsed">
          <WrapPanel.Resources>
            <Style TargetType="Button" BasedOn="{StaticResource GhostButton}">
              <Setter Property="Height" Value="30"/><Setter Property="Margin" Value="0,0,7,7"/><Setter Property="FontSize" Value="12"/>
            </Style>
          </WrapPanel.Resources>
          <Button Content="D:\SD\outputs (+3)" Click="StartScan_Click"/>
          <Button Content="E:\art\upscaled" Click="StartScan_Click"/>
          <Button Content="D:\SD\favorites" Click="StartScan_Click"/>
        </WrapPanel>

        <!-- scanning progress -->
        <StackPanel x:Name="ScanPanel" Visibility="Collapsed" Margin="0,26,0,0">
          <Grid Margin="0,0,0,8">
            <TextBlock x:Name="ScanLabel" Text="0 / 12,480 files" Foreground="{StaticResource TextSecondary}" FontSize="13" HorizontalAlignment="Left"/>
            <TextBlock x:Name="ScanPercent" Text="0%" Foreground="{StaticResource TextSecondary}" FontSize="13" HorizontalAlignment="Right"/>
          </Grid>
          <ProgressBar x:Name="ScanBar" Height="6" Minimum="0" Maximum="100" Value="0">
            <ProgressBar.Template>
              <ControlTemplate TargetType="ProgressBar">
                <Border CornerRadius="3" Background="{StaticResource BgTertiary}">
                  <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,0"><GradientStop Color="#6366F1" Offset="0"/><GradientStop Color="#818CF8" Offset="1"/></LinearGradientBrush>
                    </Border.Background>
                  </Border>
                </Border>
              </ControlTemplate>
            </ProgressBar.Template>
          </ProgressBar>
          <Border CornerRadius="8" Background="#05FFFFFF" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="0,8" Margin="0,10,0,0">
            <TextBlock x:Name="ScanMessage" Text="Scanning files…" Foreground="{StaticResource TextSecondary}" FontSize="12.5" HorizontalAlignment="Center"/>
          </Border>
        </StackPanel>
      </StackPanel>
    </Grid>

    <!-- ═══════════════ Modal ═══════════════ -->
    <Grid x:Name="Modal" Grid.RowSpan="3" Visibility="Collapsed" Background="#EB040407">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- topbar -->
      <DockPanel Grid.Row="0" Margin="16,12" LastChildFill="False">
        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock x:Name="ModalTitle" Text="00427-portrait.png · 832 × 1216 · animagineXL_v31" Foreground="{StaticResource TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
          <TextBlock x:Name="ModalSourceLabel" Text="Original" Foreground="{StaticResource TextTertiary}" FontSize="11.5" Margin="10,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
        <Button DockPanel.Dock="Right" x:Name="ModalCloseBtn" Style="{StaticResource IconButton}" Click="CloseModal_Click" ToolTip="Close (Esc)" Width="38" Height="38">
          <Path Data="M18,6 L6,18 M6,6 L18,18" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.8" Stretch="Uniform" Width="16" Height="16"/>
        </Button>
        <Button x:Name="ModalMetadataSidebarToggleButton" DockPanel.Dock="Right" Style="{StaticResource IconButton}" Click="ToggleModalMetadataSidebar_Click" ToolTip="Show metadata sidebar" Width="38" Height="38">
          <TextBlock x:Name="ModalMetadataSidebarToggleLabel" Text="&lt;" Foreground="{StaticResource TextSecondary}" FontSize="15" FontWeight="SemiBold"/>
        </Button>
        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" ToolTip="Open externally" Width="38" Height="38" Click="OpenSelectedExternally_Click">
          <Path Data="M18,13 v6 a2,2 0 0 1 -2,2 H5 a2,2 0 0 1 -2,-2 V8 a2,2 0 0 1 2,-2 h6 M15,3 h6 v6 M10,14 L21,3" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Stretch="Uniform" Width="15" Height="15"/>
        </Button>
        <Button x:Name="ModalEnhancedToggleButton" DockPanel.Dock="Right" Style="{StaticResource IconButton}" ToolTip="No enhanced output available" Width="42" Height="38" Click="ToggleModalEnhanced_Click" IsEnabled="False">
          <TextBlock x:Name="ModalEnhancedToggleLabel" Text="OR" Foreground="{StaticResource TextSecondary}" FontSize="10.5" FontWeight="SemiBold"/>
        </Button>
        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" ToolTip="Flip horizontal (H)" Width="38" Height="38" Click="ToggleModalFlip_Click">
          <Path Data="M12,3 v18 M6,8 l-4,4 l4,4 M18,8 l4,4 l-4,4" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.7" Stretch="Uniform" Width="16" Height="16"/>
        </Button>
        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" ToolTip="Favorite -1 (X)" Width="38" Height="38" Click="ModalFavoriteDecrease_Click">
          <TextBlock Text="−" Foreground="{StaticResource TextSecondary}" FontSize="16"/>
        </Button>
        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" ToolTip="Favorite +1" Width="46" Height="38" Click="ModalFavoriteIncrease_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="F" Foreground="{StaticResource FavoriteText}" FontWeight="Bold"/>
            <TextBlock x:Name="ModalFavoriteLevelText" Text="0" Foreground="{StaticResource FavoriteText}" FontSize="11" FontWeight="Bold" Margin="4,0,0,0"/>
          </StackPanel>
        </Button>
        <Button DockPanel.Dock="Right" Style="{StaticResource IconButton}" ToolTip="Reset zoom (0)" Width="42" Height="38" Click="ResetModalTransform_Click">
          <TextBlock Text="1:1" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
        </Button>
      </DockPanel>

      <!-- image area -->
      <Grid Grid.Row="1" Margin="0,0,0,16">
        <Border x:Name="ModalImage" Width="440" Height="640" CornerRadius="6" ClipToBounds="True" HorizontalAlignment="Center" VerticalAlignment="Center"
                MouseLeftButtonDown="ModalImage_MouseLeftButtonDown" MouseMove="ModalImage_MouseMove"
                MouseLeftButtonUp="ModalImage_MouseLeftButtonUp" LostMouseCapture="ModalImage_LostMouseCapture">
          <Border.Effect><DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.6" Color="Black"/></Border.Effect>
          <Grid x:Name="ModalVisual" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <TransformGroup>
                <ScaleTransform x:Name="ModalVisualTransform" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="ModalPanTransform" X="0" Y="0"/>
              </TransformGroup>
            </Grid.RenderTransform>
            <Rectangle x:Name="ModalArtBase"/>
            <Rectangle x:Name="ModalArtGlow"/>
            <Image x:Name="ModalBitmap" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
          </Grid>
        </Border>

        <Button HorizontalAlignment="Left" Width="72" Style="{StaticResource IconButton}" Height="640" ToolTip="Previous (←)" Background="Transparent" Click="ModalPrevious_Click">
          <Border Width="44" Height="44" CornerRadius="999" Background="#14FFFFFF" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1">
            <Path Data="M15,18 l-6,-6 l6,-6" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.8" Stretch="Uniform" Width="18" Height="18"/>
          </Border>
        </Button>
        <Button HorizontalAlignment="Right" Width="72" Style="{StaticResource IconButton}" Height="640" ToolTip="Next (→)" Background="Transparent" Click="ModalNext_Click">
          <Border Width="44" Height="44" CornerRadius="999" Background="#14FFFFFF" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1">
            <Path Data="M9,18 l6,-6 l-6,-6" Stroke="{StaticResource TextSecondary}" StrokeThickness="1.8" Stretch="Uniform" Width="18" Height="18"/>
          </Border>
        </Button>

        <Border x:Name="ModalMetadataSidebar" HorizontalAlignment="Right" VerticalAlignment="Center" Width="300" MaxHeight="640" Visibility="Collapsed"
                Margin="0,0,84,0" CornerRadius="10" Background="#E6121218" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" Padding="12">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
              <Border Background="{StaticResource SoftFill}" CornerRadius="7" Padding="3" Margin="0,0,0,12">
                <UniformGrid Columns="3">
                  <RadioButton x:Name="ModalPromptTabButton" Style="{StaticResource Seg}" GroupName="ModalMetadataTabs"
                               Content="Prompt" Tag="prompt" IsChecked="True" Click="ModalMetadataTab_Click"/>
                  <RadioButton x:Name="ModalNegativeTabButton" Style="{StaticResource Seg}" GroupName="ModalMetadataTabs"
                               Content="Negative" Tag="negative" Click="ModalMetadataTab_Click"/>
                  <RadioButton x:Name="ModalSettingsTabButton" Style="{StaticResource Seg}" GroupName="ModalMetadataTabs"
                               Content="Settings" Tag="settings" Click="ModalMetadataTab_Click"/>
                </UniformGrid>
              </Border>

              <StackPanel x:Name="ModalPromptPanel">
                <DockPanel Margin="0,0,0,6">
                  <TextBlock Text="PROMPT" Foreground="{StaticResource TextTertiary}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <Button x:Name="CopyModalPromptButton" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Height="24" MinWidth="52" Padding="8,2"
                          Content="Copy" IsEnabled="False" ToolTip="No prompt metadata loaded" Click="CopyPreviewPrompt_Click"/>
                </DockPanel>
                <TextBlock x:Name="ModalPromptText" Text="-" Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="18" MaxHeight="180" Margin="0,0,0,12"/>
              </StackPanel>

              <StackPanel x:Name="ModalNegativePanel" Visibility="Collapsed">
                <DockPanel Margin="0,0,0,6">
                  <TextBlock Text="NEGATIVE" Foreground="{StaticResource TextTertiary}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                  <Button x:Name="CopyModalNegativeButton" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Height="24" MinWidth="52" Padding="8,2"
                          Content="Copy" IsEnabled="False" ToolTip="No negative prompt metadata loaded" Click="CopyPreviewNegative_Click"/>
                </DockPanel>
                <TextBlock x:Name="ModalNegativeText" Text="-" Foreground="#F5A5A5" FontSize="12" TextWrapping="Wrap" LineHeight="18" MaxHeight="180" Margin="0,0,0,12"/>
              </StackPanel>

              <StackPanel x:Name="ModalSettingsPanel" Visibility="Collapsed">
                <TextBlock Text="GENERATION SETTINGS" Foreground="{StaticResource TextTertiary}" FontSize="10.5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <TextBlock x:Name="ModalSettingsText" Text="No settings metadata." Foreground="{StaticResource TextSecondary}" FontSize="12"
                           FontFamily="{StaticResource MonoFont}" TextWrapping="Wrap" LineHeight="18" MaxHeight="180" Margin="0,0,0,12"/>
              </StackPanel>

              <Border Height="1" Background="{StaticResource GlassBorder}" Margin="0,0,0,12"/>
              <DockPanel Margin="0,0,0,8">
                <TextBlock Text="PNG INFO" Foreground="{StaticResource TextTertiary}" FontSize="10.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button x:Name="CopyModalMetadataButton" DockPanel.Dock="Right" Style="{StaticResource GhostButton}" Height="24" MinWidth="52" Padding="8,2"
                        Content="Copy" IsEnabled="False" ToolTip="No PNG metadata loaded" Click="CopyPreviewMetadata_Click"/>
              </DockPanel>
              <TextBlock x:Name="ModalMetadataStatusText" Text="No PNG metadata loaded" Foreground="{StaticResource TextTertiary}" FontSize="12" TextWrapping="Wrap"/>
            </StackPanel>
          </ScrollViewer>
        </Border>

        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" CornerRadius="999" Background="#80000000" Padding="12,5" Margin="0,0,0,10">
          <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12">
            <Run x:Name="ModalZoomLabel" Text="100%"/><Run Text="   ·   ← → navigate   ·   +/- zoom   ·   Esc close" Foreground="{StaticResource TextTertiary}"/>
          </TextBlock>
        </Border>
      </Grid>
    </Grid>

  </Grid>
</Window>
